{
  "name": "tangu-agent-desktop2",
  "version": "2.0.0",
  "description": "Tangu Agent Desktop 2.0 — Obsidian 式工作区引擎(Electron),连 standalone 服务",
  "author": "Forsion",
  "private": true,
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev --noSandbox",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "web": "vite frontend",
    "test": "vitest run",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/language-data": "^6.5.1",
    "@uiw/react-codemirror": "^4.25.2",
    "diff2html": "^3.4.55",
    "dockview": "^7.0.2",
    "dockview-react": "^7.0.2",
    "docx-preview": "^0.3.5",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.40.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.27",
    "lucide-react": "^1.17.0",
    "pdfjs-dist": "^5.7.284",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@iarna/toml": "^2.2.5",
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.8.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "gray-matter": "^4.0.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "yaml": "^2.9.0"
  },
  "build": {
    "appId": "com.forsion.tangu-desktop2",
    "productName": "Tangu Agent 2.0",
    "afterPack": "build/afterPack.cjs",
    "publish": { "provider": "github", "owner": "Changan-Su", "repo": "Tangu" },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      { "from": "../dist", "to": "tangu-server/dist" },
      { "from": "../node_modules", "to": "tangu-server/node_modules" },
      { "from": "../package.json", "to": "tangu-server/package.json" }
    ],
    "linux": { "target": "AppImage", "icon": "build/icon.png" },
    "mac": { "target": "dmg", "icon": "build/icon.icns" },
    "win": { "target": "nsis", "icon": "build/icon.ico" }
  }
}
