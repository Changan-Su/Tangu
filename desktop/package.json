{
  "name": "tangu-agent-desktop2",
  "version": "2.3.0",
  "description": "Tangu Agent Desktop 2.0 — Obsidian 式工作区引擎(Electron),连 standalone 服务",
  "author": "Forsion",
  "private": true,
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev --noSandbox",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "web": "vite frontend",
    "test": "vitest run",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "fetch-python": "node build/fetch-python.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/language-data": "^6.5.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@milkdown/kit": "^7.21.2",
    "@milkdown/plugin-math": "^7.5.9",
    "@milkdown/react": "^7.21.2",
    "@milkdown/theme-nord": "^7.21.2",
    "@uiw/react-codemirror": "^4.25.2",
    "chokidar": "^5.0.0",
    "diff2html": "^3.4.55",
    "dockview": "^7.0.2",
    "dockview-react": "^7.0.2",
    "docx-preview": "^0.3.5",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.40.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.27",
    "lucide-react": "^1.17.0",
    "nanoid": "^5.1.11",
    "pdfjs-dist": "^5.7.284",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@iarna/toml": "^2.2.5",
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.8.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "gray-matter": "^4.0.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "yaml": "^2.9.0"
  },
  "build": {
    "appId": "com.forsion.tangu-desktop2",
    "productName": "Tangu Agent 2.0",
    "beforeBuild": "build/beforeBuild.cjs",
    "afterPack": "build/afterPack.cjs",
    "publish": {
      "provider": "github",
      "owner": "Changan-Su",
      "repo": "Tangu"
    },
    "artifactName": "Tangu-Agent-${version}-${arch}.${ext}",
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "!node_modules/.bin",
      "!node_modules/**/*.{d.ts,map,md,markdown}",
      "!node_modules/typescript/**",
      "!node_modules/vite/**",
      "!node_modules/vitest/**",
      "!node_modules/@vitest/**",
      "!node_modules/@vitejs/**",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!node_modules/electron-vite/**",
      "!node_modules/app-builder-lib/**",
      "!node_modules/dmg-builder/**",
      "!node_modules/esbuild/**",
      "!node_modules/@esbuild/**",
      "!node_modules/rollup/**",
      "!node_modules/@rollup/**",
      "!node_modules/@types/**"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "tangu-server/dist"
      },
      {
        "from": "../node_modules",
        "to": "tangu-server/node_modules"
      },
      {
        "from": "../package.json",
        "to": "tangu-server/package.json"
      },
      {
        "from": "../skills",
        "to": "tangu-server/skills"
      },
      {
        "from": "build/python",
        "to": "python"
      }
    ],
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "identity": null
    },
    "dmg": {
      "window": {
        "width": 560,
        "height": 440
      },
      "contents": [
        {
          "x": 150,
          "y": 200
        },
        {
          "x": 410,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 280,
          "y": 372,
          "type": "file",
          "path": "build/打不开请先读我.txt"
        }
      ]
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
