{
  "name": "forsion-desktop",
  "version": "2.6.1",
  "description": "Forsion Desktop — AI 驱动的应用生态系统的桌面端(Electron):Tangu Agent 引擎 + LCL 可停靠工作区框架 + 可插拔功能空间(对话/笔记/日历/收件箱/编码),按产品档案裁出全家桶与单品发行版",
  "author": "Forsion",
  "private": true,
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "postinstall": "node build/link-lcl.cjs && node build/copy-excalidraw-assets.cjs",
    "dev": "electron-vite dev --noSandbox",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "web": "vite frontend",
    "test": "vitest run",
    "e2e:editor": "node scripts/e2e-editor.cjs",
    "e2e:dnd": "node scripts/block-dnd.e2e.cjs",
    "check:pillbar": "node scripts/pillbar-overflow.check.cjs",
    "check:leadicon": "node scripts/t2s-lead-icon.check.cjs",
    "pack": "electron-builder --config electron-builder.config.cjs --dir",
    "dist": "electron-builder --config electron-builder.config.cjs",
    "fetch-python": "node build/fetch-python.cjs",
    "typecheck": "tsc --noEmit",
    "dev:amadeus": "FORSION_PRODUCT=amadeus electron-vite dev --noSandbox",
    "build:amadeus": "FORSION_PRODUCT=amadeus electron-vite build",
    "pack:amadeus": "FORSION_PRODUCT=amadeus npm run build:amadeus && FORSION_PRODUCT=amadeus electron-builder --config electron-builder.config.cjs --dir"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.4",
    "@astryxdesign/theme-neutral": "^0.1.4",
    "@codemirror/language-data": "^6.5.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@excalidraw/excalidraw": "^0.18.1",
    "@milkdown/kit": "^7.21.2",
    "@milkdown/plugin-math": "^7.5.9",
    "@milkdown/react": "^7.21.2",
    "@milkdown/theme-nord": "^7.21.2",
    "@stylexjs/stylex": "^0.18.3",
    "@uiw/react-codemirror": "^4.25.2",
    "chokidar": "^5.0.0",
    "diff2html": "^3.4.55",
    "dockview": "^7.0.2",
    "dockview-react": "^7.0.2",
    "docx-preview": "^0.3.5",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.40.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.27",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.17.0",
    "lz-string": "^1.5.0",
    "nanoid": "^5.1.11",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.7.284",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "sherpa-onnx-node": "^1.13.4",
    "sucrase": "^3.35.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@iarna/toml": "^2.2.5",
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.8.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "gray-matter": "^4.0.3",
    "happy-dom": "^20.10.6",
    "playwright-core": "^1.61.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "yaml": "^2.9.0"
  }
}
