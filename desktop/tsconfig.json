{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["frontend/src/*"],
      "@amadeus/*": ["frontend/src/amadeus/*"],
      "@amadeus-shared/*": ["shared/amadeus/*"]
    }
  },
  "include": ["electron/**/*", "frontend/src/**/*", "shared/**/*"]
}
