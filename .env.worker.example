# Tangu Agent worker 配置示例 —— 复制为 .env.worker 后填写
# 形态说明见 README「worker（分离式云节点）」与 docker-compose.worker.yml

# 【必填】与 Forsion server 同一 JWT 密钥（本地验签 forsion_token + 铸 per-user token）
JWT_SECRET=

# 【必填】Forsion 云端 brain-api 地址（LLM / 记忆 / 技能 / 计费收口）
TANGU_CLOUD_URL=https://api.forsion.app

# 【必填】共享云端 Postgres，必须与 Forsion server 同一个库（run/会话态跨 worker 共享）
TANGU_DB_URL=postgres://user:password@db-host:5432/forsion

# 本 worker 服务的 app（一个 fleet 服一个 app），默认 ai-studio
TANGU_APP_ID=ai-studio

# 默认模型 id（可选；不填由请求携带）
TANGU_MODEL=

# 沙箱模式 docker|none|auto。compose 已挂 docker.sock → 用 docker；不需要 run_python 可设 none
TANGU_SANDBOX=docker
