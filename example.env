# Tangu Agent 环境变量模板
#
# 用法:复制到 ~/.tangu/.env(标准位置,CLI/TUI/桌面端启动时自动加载),
#       或直接 export 进 shell 环境(真实环境变量优先于 .env 文件)。
#   cp example.env ~/.tangu/.env
#
# 配好 TANGU_CLOUD_URL 后,桌面端/TUI 只需登录(浏览器 device flow),无需再手填地址。

# ── Forsion 云端(大脑:托管模型/记忆/云端技能)─────────────────────────────
# 云端地址。配置后桌面端连接页/首启引导自动预填,登录即用。
TANGU_CLOUD_URL=https://api.forsion.app

# forsion_token(可选)。一般不需要:`tangu login` / 桌面端浏览器登录后凭证存
# ~/.tangu/auth.json 自动复用。仅无头部署(CI/服务器)时显式给 token。
# TANGU_TOKEN=

# ── 模型 / 存储 / 服务 ────────────────────────────────────────────────────
# 默认模型 id(run 未指定时用;桌面端/TUI 内也可随时切换)
# TANGU_MODEL=DeepSeek-V4-Pro

# 嵌入式 PGlite 数据目录(默认 ~/.tangu/pgdata;'memory'=内存不落盘)
# TANGU_DATA_DIR=

# 外部 Postgres(配置后不用 PGlite)
# TANGU_DATABASE_URL=postgresql://user:pass@localhost:5432/tangu

# tangu-server 监听(默认 127.0.0.1:8787)
# TANGU_PORT=8787
# TANGU_HOST=127.0.0.1

# 代码沙箱:auto(默认,检测到 docker 即开)| docker | none
# TANGU_SANDBOX=auto

# ── 直连 provider(BYO-key;多 provider 建议用 ~/.tangu/providers.json 或桌面端 Provider 页)──
# TANGU_PROVIDER_ID=ollama
# TANGU_PROVIDER_BASE_URL=http://localhost:11434/v1
# TANGU_PROVIDER_API_KEY=
# TANGU_PROVIDER_MODELS=llama3,qwen2.5-coder
# TANGU_PROVIDERS_FILE=

# ── 桌面端 ────────────────────────────────────────────────────────────────
# external 模式的外部 tangu-server 地址(managed 托管模式不需要)
# TANGU_BACKEND_URL=http://localhost:8787

# ── 其他 ──────────────────────────────────────────────────────────────────
# 整体重定向 ~/.tangu(测试/多实例;只能来自真实环境变量,不能写在本文件)
# TANGU_HOME=

# 本地单用户 id(默认 local)
# TANGU_USER_ID=local

# 关闭外部生态技能的实时加载(默认开:自动识别 ~/.claude/skills 与 ~/.codex/prompts)
# TANGU_EXTERNAL_SKILLS=off
